PORT=4000
NODE_ENV=development

# ---- 鉴权 ----
# 生产环境务必改成 64 位随机字符串：openssl rand -hex 32
JWT_SECRET=dev-insecure-please-override-in-production
JWT_EXPIRES_IN=7d

# ---- 微软 OAuth2 ----
# Token 端点（通常无需修改）
MS_TOKEN_ENDPOINT=https://login.microsoftonline.com/common/oauth2/v2.0/token

# ---- 上游 HTTP 代理（可选） ----
# 云厂商常封 993 IMAP 出站，留空则直连；填了后 axios(OAuth) 和 imapflow(IMAP) 都走代理。
# 示例：UPSTREAM_PROXY=http://user:pass@proxy.example.com:3128
# UPSTREAM_PROXY=
